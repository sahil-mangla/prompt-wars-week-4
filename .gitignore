# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing & coverage
/coverage
test_output.txt

# next.js build and swc compilation cache
/.next/
/out/
/.swc/

# production build
/build

# local env files
.env*
!.env.example
!.env.local.example

# vercel
.vercel

# typescript compiler cache
*.tsbuildinfo
next-env.d.ts

# debug logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# system files
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# IDE/Editor settings (VS Code, WebStorm, etc.)
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# local package cache
.npm-cache/

# AI development instructions (keep private)
CLAUDE.md
AGENTS.md
