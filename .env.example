# MatchMind — Environment Variables Reference
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.

# ============================================================
# FIREBASE (Browser-safe — exposed in client bundle)
# Note: If these keys are left empty, missing, or contain the word "mock" (e.g. mock_project_id),
# the app will automatically bypass Firebase and run in LocalSync Mode (HTML5 BroadcastChannel).
# This prevents client-side adblockers from blocking Firebase network requests and spaming logs.
# ============================================================
NEXT_PUBLIC_FIREBASE_API_KEY=mock_firebase_api_key_for_local_testing
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=mock_project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=mock_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=mock_project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=mock_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=mock_app_id

# ============================================================
# GEMINI API (SERVER-SIDE ONLY — NEVER use NEXT_PUBLIC_ prefix)
# Used in /app/api/translate/route.js for multilingual task dispatch
# The key is accessed only via process.env.GEMINI_API_KEY
# on the Next.js server — it is NEVER sent to the browser.
# ============================================================
GEMINI_API_KEY=your_gemini_api_key_here

# Model Selection (optional — defaults to gemini-2.5-flash)
GEMINI_MODEL=gemini-2.5-flash

# ============================================================
# OPTIONAL: Analytics & Monitoring
# ============================================================
# NEXT_PUBLIC_ANALYTICS_ID=your_ga4_id
